<Window x:Class="CyberSecurtyChatBotPart2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Chatbot"
        Height="600"
        Width="800">

    <Grid x:Name="MainGrid">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="31*"/>
            <ColumnDefinition Width="169*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Margin="10,10,10,10" Grid.ColumnSpan="2">

            <ScrollViewer Height="450"
                          VerticalScrollBarVisibility="Auto">

                <StackPanel x:Name="ChatPanel">
                    <Image Height="100" Width="100"/>
                    <Image Height="100" Width="100"/>
                </StackPanel>

            </ScrollViewer>

            <TextBox x:Name="UserInput"
                     Height="40"
                     FontSize="16"
                     Margin="0,10,0,10"/>

            <Button Content="Send"
                    Height="40"
                    FontSize="16"
                    Click="SendButton_Click"/>

        </StackPanel>
        <Image HorizontalAlignment="Left" Height="113" Margin="10,10,0,0" VerticalAlignment="Top" Width="64"/>
        <Image Margin="0,15,591,446" Source="/WhatsApp Image 2026-05-22 at 13.22.20.jpeg" Stretch="Fill" Grid.ColumnSpan="2"/>

    </Grid>

</Window>

